      <span class="project-tag">Dev · 2023</span>
    </div>
    <div class="project-card">
      <span class="project-number">05</span>
      <h3 class="project-name">Fifth Project</h3>
      <p class="project-desc">Brief description of this project and its impact.</p>
      <span class="project-tag">UX · 2023</span>
    </div>
  </div>
</section>

<!-- ── TIMELINES ── -->
<section id="timelines">
  <div class="section-label" style="margin-bottom: 1rem;">Journey</div>
  <h2 class="projects-title">Timelines</h2>
  <div class="timeline" style="margin-top: 4rem;">
    <div class="timeline-item">
      <span class="timeline-year">2024 — Present</span>
      <div class="timeline-content">
        <h3>Current Role or Study</h3>
        <p>Describe what you're doing now — job, degree, freelance work, personal projects. What are you learning and building?</p>
      </div>
    </div>
    <div class="timeline-item">
      <span class="timeline-year">2022 — 2024</span>
