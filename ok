<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Porpavai V Kannan</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Archivo:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cherry: #48182F;
      --moonstone: #D4CBC4;
      --moonstone-dark: #b8aea6;
      --moonstone-light: #ede8e4;
      --off-white: #f7f4f1;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background-color: var(--off-white);
      color: var(--cherry);
      font-family: 'Archivo', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      background-color: var(--cherry);
      padding: 0 4rem;
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      justify-content: space-between;
      border-bottom: 1px solid rgba(212,203,196,0.2);
    }

    .header-name {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 1.4rem 0;
      text-decoration: none;
    }

    .header-name span.star {
      color: var(--moonstone);
      font-size: 1rem;
      opacity: 0.7;
      letter-spacing: 0;
    }

    .header-name h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 1.35rem;
      color: var(--moonstone);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    nav {
      display: flex;
      align-items: center;
      gap: 0;
    }

    nav a {
      color: var(--moonstone);
      text-decoration: none;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 400;
      padding: 0 1.4rem;
      height: 100%;
      display: flex;
      align-items: center;
      border-left: 1px solid rgba(212,203,196,0.15);
      transition: background 0.2s, color 0.2s;
      position: relative;
    }

    nav a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--moonstone);
      transition: width 0.3s ease;
    }

    nav a:hover::after {
      width: 100%;
    }

    nav a:hover {
      background: rgba(212,203,196,0.08);
    }

    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 88vh;
      border-bottom: 1px solid var(--moonstone-dark);
    }

    .hero-left {
      background-color: var(--cherry);
      padding: 6rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      position: relative;
      overflow: hidden;
    }

    .hero-left::before {
      content: '☆';
      position: absolute;
      top: 3rem;
      right: 3rem;
      font-size: 12rem;
      color: rgba(212,203,196,0.06);
      line-height: 1;
    }

    .hero-issue {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
      margin-bottom: 2rem;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 7vw, 6rem);
      font-weight: 300;
      color: var(--moonstone);
      line-height: 1.0;
      letter-spacing: -0.01em;
      margin-bottom: 2rem;
    }

    .hero-title em {
      font-style: italic;
      opacity: 0.7;
    }

    .hero-tagline {
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
      max-width: 22rem;
      line-height: 2;
    }

    .hero-right {
      background-color: var(--moonstone-light);
      padding: 6rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 3rem;
      border-left: 1px solid var(--moonstone-dark);
    }

    .hero-intro-label {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--moonstone-dark);
      display: block;
    }

    .hero-intro-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 300;
      line-height: 1.7;
      color: var(--cherry);
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--moonstone-dark);
    }

    .stat-label {
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
      margin-bottom: 0.4rem;
      display: block;
    }

    .stat-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--cherry);
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-size: 0.6rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--moonstone-dark);
    }

    /* ── PROJECTS ── */
    #projects {
      padding: 6rem 4rem;
      background: var(--off-white);
    }

    .projects-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 4rem;
    }

    .projects-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 300;
      color: var(--cherry);
    }

    .magazine-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1px;
      background: var(--moonstone-dark);
      border: 1px solid var(--moonstone-dark);
    }

    .project-card {
      background: var(--off-white);
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: background 0.25s;
      cursor: pointer;
    }

    .project-card:hover {
      background: var(--moonstone-light);
    }

    .project-card.featured {
      grid-row: span 2;
      background: var(--cherry);
    }

    .project-card.featured:hover {
      background: #5a1f3b;
    }

    .project-card.featured .project-name,
    .project-card.featured .project-desc,
    .project-card.featured .project-tag {
      color: var(--moonstone);
    }

    .project-card.featured .project-tag {
      border-color: rgba(212,203,196,0.3);
      color: var(--moonstone-dark);
    }

    .project-number {
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      color: var(--moonstone-dark);
    }

    .project-card.featured .project-number {
      color: rgba(212,203,196,0.5);
    }

    .project-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 400;
      color: var(--cherry);
      line-height: 1.2;
      flex: 1;
    }

    .project-card.featured .project-name {
      font-size: 2.4rem;
    }

    .project-desc {
      font-size: 0.78rem;
      line-height: 1.8;
      color: #6b4a59;
    }

    .project-tag {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      border: 1px solid var(--moonstone-dark);
      padding: 0.3rem 0.8rem;
      display: inline-block;
      width: fit-content;
      color: var(--moonstone-dark);
    }

    /* ── TIMELINE ── */
    #timelines {
      padding: 6rem 4rem;
      background: var(--cherry);
    }

    #timelines .projects-title {
      color: var(--moonstone);
      margin-bottom: 4rem;
    }

    #timelines .section-label {
      color: rgba(212,203,196,0.5);
    }

    #timelines .section-label::after {
      background: rgba(212,203,196,0.2);
    }

    .timeline {
      position: relative;
      padding-left: 2rem;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 1px;
      background: rgba(212,203,196,0.2);
    }

    .timeline-item {
      position: relative;
      padding: 0 0 3.5rem 2.5rem;
      display: grid;
      grid-template-columns: 10rem 1fr;
      gap: 2rem;
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: -0.3rem;
      top: 0.35rem;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: var(--moonstone);
    }

    .timeline-year {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      color: rgba(212,203,196,0.5);
      padding-top: 0.15rem;
    }

    .timeline-content h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--moonstone);
      margin-bottom: 0.5rem;
    }

    .timeline-content p {
      font-size: 0.78rem;
      color: rgba(212,203,196,0.6);
      line-height: 1.8;
    }

    /* ── RESUME ── */
    #resume {
      padding: 6rem 4rem;
      background: var(--moonstone-light);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }

    .resume-col h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300;
      color: var(--cherry);
      margin-bottom: 3rem;
    }

    .resume-entry {
      padding: 1.8rem 0;
      border-top: 1px solid var(--moonstone-dark);
    }

    .resume-entry:last-child {
      border-bottom: 1px solid var(--moonstone-dark);
    }

    .resume-entry-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 0.4rem;
    }

    .resume-role {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--cherry);
    }

    .resume-date {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
    }

    .resume-org {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      color: #8a6070;
      margin-bottom: 0.6rem;
      text-transform: uppercase;
    }

    .resume-desc {
      font-size: 0.78rem;
      color: #6b4a59;
      line-height: 1.8;
    }

    .resume-download {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      margin-top: 3rem;
      background: var(--cherry);
      color: var(--moonstone);
      padding: 1rem 2rem;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .resume-download:hover {
      opacity: 0.85;
    }

    /* ── HELLO ── */
    #hello {
      padding: 6rem 4rem;
      background: var(--off-white);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }

    .hello-left h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 6vw, 5rem);
      font-weight: 300;
      color: var(--cherry);
      line-height: 1.05;
      margin-bottom: 2rem;
    }

    .hello-left p {
      font-size: 0.82rem;
      line-height: 2;
      color: #6b4a59;
      max-width: 32rem;
    }

    .hello-right {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .contact-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 0;
      border-top: 1px solid var(--moonstone-dark);
      text-decoration: none;
      transition: padding-left 0.2s;
    }

    .contact-item:last-child {
      border-bottom: 1px solid var(--moonstone-dark);
    }

    .contact-item:hover {
      padding-left: 1rem;
    }

    .contact-label {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--moonstone-dark);
    }

    .contact-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--cherry);
    }

    .contact-arrow {
      color: var(--moonstone-dark);
      font-size: 0.8rem;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--cherry);
      padding: 2rem 4rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    footer p {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(212,203,196,0.4);
    }

    footer span {
      color: var(--moonstone);
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-issue, .hero-title, .hero-tagline, .hero-intro-label, .hero-intro-text, .hero-stats {
      animation: fadeUp 0.8s ease both;
    }

    .hero-issue        { animation-delay: 0.1s; }
    .hero-title        { animation-delay: 0.2s; }
    .hero-tagline      { animation-delay: 0.35s; }
    .hero-intro-label  { animation-delay: 0.25s; }
    .hero-intro-text   { animation-delay: 0.4s; }
    .hero-stats        { animation-delay: 0.55s; }

    /* ── MOBILE ── */
    @media (max-width: 768px) {
      header { padding: 0 1.5rem; flex-direction: column; align-items: flex-start; gap: 0; }
      nav { width: 100%; overflow-x: auto; }
      nav a { padding: 0 1rem; font-size: 0.65rem; border-left: none; border-right: 1px solid rgba(212,203,196,0.15); white-space: nowrap; }
      .hero, #resume, #hello { grid-template-columns: 1fr; }
      .hero-left, .hero-right, #resume, #hello, #projects, #timelines { padding: 3rem 1.5rem; }
      .magazine-grid { grid-template-columns: 1fr; }
      .project-card.featured { grid-row: span 1; }
      .timeline-item { grid-template-columns: 1fr; gap: 0.5rem; }
      footer { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
  </style>
</head>
