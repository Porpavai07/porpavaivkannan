      <div class="timeline-content">
        <h3>Where It All Started ☆</h3>
        <p>The spark. What made you fall in love with what you do?</p>
      </div>
    </div>
  </div>
</section>

<!-- ── RESUME ── -->
<section id="resume">
  <div class="resume-col">
    <div class="section-label" style="margin-bottom: 1rem;">Experience</div>
    <h2>Resume</h2>
    <div class="resume-entry">
      <div class="resume-entry-top">
